---
---
<button class="music-button" id="musicBtn">
    <svg class="music-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18V5l12-2v13" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="6" cy="18" r="3"/>
        <circle cx="18" cy="16" r="3"/>
    </svg>
</button>

<audio id="weddingMusic" loop>
    <!-- Asegúrate de tener este archivo en "public/Prometo.mp3" -->
    <source src="/Prometo.mp3" type="audio/mpeg" />
</audio>

<script>
    const musicBtn = document.getElementById("musicBtn");
    const audio = document.getElementById("weddingMusic") as HTMLAudioElement;
    let isPlaying = false;

    const playMusic = () => {
        if (!isPlaying && audio) {
            audio.play().then(() => {
                isPlaying = true;
                musicBtn?.classList.add("playing");
            }).catch(e => console.log('Autoplay blocked or failed', e));
        }
    };

    const stopMusic = () => {
        if (isPlaying && audio) {
            audio.pause();
            isPlaying = false;
            musicBtn?.classList.remove("playing");
        }
    };

    // Try to play on first click anywhere in the document (the interaction trick)
    const handleFirstInteraction = () => {
        playMusic();
        document.removeEventListener("click", handleFirstInteraction);
        document.removeEventListener("touchstart", handleFirstInteraction);
    };

    document.addEventListener("click", handleFirstInteraction);
    document.addEventListener("touchstart", handleFirstInteraction);

    if (musicBtn && audio) {
        musicBtn.addEventListener("click", (e) => {
            e.stopPropagation(); // Prevent the document listener from firing again if it hasn't yet
            if (isPlaying) {
                stopMusic();
            } else {
                playMusic();
            }
        });
    }
</script>
