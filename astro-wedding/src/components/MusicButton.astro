---
---
<button class="music-mini-player" id="musicBtn" aria-label="Reproducir música">
    <div class="player-content">
        <div class="music-bars">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </div>
        <span class="player-text">Música</span>
    </div>
    <div class="play-pause-icon">
        <svg class="icon-play" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
        </svg>
        <svg class="icon-pause" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
    </div>
</button>

<audio id="weddingMusic" loop preload="auto">
    <source src="/Prometo.mp3" type="audio/mpeg" />
</audio>

<style>
    .music-mini-player {
        position: fixed;
        top: 25px;
        right: 25px;
        height: 40px;
        padding: 0 15px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(74, 144, 226, 0.2);
        color: var(--color-primary, #4a90e2);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        z-index: 9999;
    }

    .music-mini-player:hover {
        background: rgba(255, 255, 255, 0.9);
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(74, 144, 226, 0.15);
    }

    .player-content {
        display: flex;
        align-items: center;
        gap: 10px;
        border-right: 1px solid rgba(74, 144, 226, 0.2);
        padding-right: 10px;
    }

    .player-text {
        font-family: var(--font-sans, sans-serif);
        font-size: 0.85rem;
        font-weight: 500;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .music-bars {
        display: flex;
        align-items: flex-end;
        gap: 2px;
        height: 12px;
        width: 14px;
    }

    .bar {
        width: 3px;
        background: var(--color-primary, #4a90e2);
        border-radius: 1px;
        height: 4px;
        transition: height 0.3s ease;
    }

    .music-mini-player.playing .bar {
        animation: musicWave 1s ease-in-out infinite;
    }

    .music-mini-player.playing .bar:nth-child(1) { animation-delay: 0.1s; }
    .music-mini-player.playing .bar:nth-child(2) { animation-delay: 0.3s; }
    .music-mini-player.playing .bar:nth-child(3) { animation-delay: 0.2s; }

    .play-pause-icon {
        width: 16px;
        height: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .icon-pause { display: none; }
    
    .music-mini-player.playing .icon-play { display: none; }
    .music-mini-player.playing .icon-pause { display: block; }

    @keyframes musicWave {
        0%, 100% { height: 4px; }
        50% { height: 12px; }
    }

    @media (max-width: 768px) {
        .music-mini-player {
            top: 20px;
            right: 20px;
            height: 36px;
            padding: 0 12px;
        }
        .player-text { display: none; }
        .player-content { border: none; padding: 0; }
    }
</style>

<script>
    const musicBtn = document.getElementById("musicBtn");
    const audio = document.getElementById("weddingMusic") as HTMLAudioElement;
    let isPlaying = false;

    const playMusic = () => {
        if (!isPlaying && audio) {
            audio.play().then(() => {
                isPlaying = true;
                musicBtn?.classList.add("playing");
            }).catch(e => {
                console.log('Autoplay blocked, waiting for interaction', e);
            });
        }
    };

    const toggleMusic = () => {
        if (isPlaying) {
            audio.pause();
            isPlaying = false;
            musicBtn?.classList.remove("playing");
        } else {
            playMusic();
        }
    };

    // Try to play as soon as possible
    window.addEventListener('load', () => {
        // Short delay to let the loader settle
        setTimeout(playMusic, 500);
    });

    // Interaction triggers
    const interactionEvents = ['click', 'touchstart', 'scroll'];
    const startOnInteraction = () => {
        playMusic();
        interactionEvents.forEach(event => document.removeEventListener(event, startOnInteraction));
    };

    interactionEvents.forEach(event => document.addEventListener(event, startOnInteraction));

    if (musicBtn) {
        musicBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            toggleMusic();
        });
    }
</script>
