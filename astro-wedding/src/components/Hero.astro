---
---
<section id="inicio" class="hero">
    <div class="hero-bg-placeholder" style="background-image: url('https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=2069&auto=format&fit=crop'); background-size: cover; background-position: center; position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.3; z-index: 0;"></div>
    <div class="hero-content" style="position: relative; z-index: 2;">
        <h1 class="hero-title">Manuel <span class="y-separator-hero">y</span> Andrea</h1>
        <p class="hero-subtitle">Nos Casamos</p>
    </div>

<style>
    .hero-title {
        font-family: var(--font-script, cursive);
        font-size: 10rem; /* Adjusted for slightly better balance with global scale */
        margin-bottom: 1.5rem;
        line-height: 1.1;
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .hero-subtitle {
        font-size: 1.6rem;
        letter-spacing: 0.6em;
        text-transform: uppercase;
        color: var(--color-text-medium);
        margin-top: 0.5rem;
    }

    @media (max-width: 768px) {
        .hero-title {
            font-size: 5.5rem;
        }
        .hero-subtitle {
            font-size: 1.1rem;
            letter-spacing: 0.3em;
        }
    }
</style>
    <div class="hero-wave">
        <svg class="wave-svg" viewBox="0 0 1200 150" preserveAspectRatio="none">
            <path d="M0,80 C300,110 500,50 600,65 C700,80 900,110 1200,80 L1200,150 L0,150 Z" 
                  fill="#FFFFFF"/>
        </svg>
    </div>
</section>
